# Whilly Orchestrator — worker-only env template (M1 split-host deployment).
#
# Pairs with `docker-compose.worker.yml`. Copy this file to `.env.worker`
# (which is gitignored) and fill in the required values BEFORE running:
#
#   cp .env.worker.example .env.worker
#   $EDITOR .env.worker
#   docker-compose -f docker-compose.worker.yml --env-file .env.worker up -d
#
# Two values are REQUIRED (compose will refuse to start without them):
#   - WHILLY_CONTROL_URL
#   - WHILLY_WORKER_BOOTSTRAP_TOKEN
#
# Everything else has a sensible default for the workshop demo path.

# ─── REQUIRED: control-plane address ──────────────────────────────────────
# Base URL of the control-plane this worker should join. Must be reachable
# from the host running this compose file (cross-host: VPS public IP or
# the rotating https://<random>.lhr.life URL published by the M2
# localhost.run `funnel` sidecar; same-host: 127.0.0.1:8000 against
# docker-compose.control-plane.yml). The worker uses this URL for both
# `whilly worker register` (one-shot bootstrap) and the long-poll claim
# loop.
#
# Examples:
#   WHILLY_CONTROL_URL=http://213.159.6.155:8000          # plain LAN/VPS
#   WHILLY_CONTROL_URL=https://abc123.lhr.life            # localhost.run funnel (M2)
WHILLY_CONTROL_URL=http://control:8000

# ─── REQUIRED: cluster-join secret ────────────────────────────────────────
# Bootstrap token minted by the control-plane operator. The worker
# entrypoint exchanges this for a per-worker bearer token via
# POST /workers/register; the bootstrap secret itself never leaves
# the registration call. Treat it like an SSH key.
#
# Mint via the control-plane operator's tooling. At M1 the token is a
# single shared cluster secret (env-var on the control-plane); at M2 the
# `whilly admin bootstrap mint --owner you@example.com` flow lands.
WHILLY_WORKER_BOOTSTRAP_TOKEN=demo-bootstrap

# ─── Identity in the audit log ────────────────────────────────────────────
# Hostname this worker self-reports during register (and in subsequent
# heartbeats). Becomes the `hostname` column on the workers table, so
# pick something humans can grep — "macbook-mvs", "vps-eu-1", etc. The
# compose file plumbs this into the container's hostname so the
# entrypoint's `$(hostname)` capture sees the same value.
#
# Default: "whilly-worker" (matches the container_name fallback so the
# events table is at least non-empty even if you forget to set it).
WHILLY_WORKER_HOSTNAME=whilly-worker

# ─── Plan to drain ────────────────────────────────────────────────────────
# Plan id this worker should claim tasks from. The control-plane is
# multi-tenant per plan; you can run multiple worker hosts against
# different plans against the same control-plane. Default matches the
# workshop demo's plan id.
# WHILLY_PLAN_ID=demo

# ─── Image / version override ─────────────────────────────────────────────
# Default tag is the current v4.6.0 release artifact (first tag that
# knows alembic migrations 010_funnel_url + 011_events_notify_trigger;
# older 4.3.1 crashed the control-plane on boot). Override for dev /
# local-build workflows. The image must contain a `whilly-worker`
# entrypoint; both the production Dockerfile and Dockerfile.demo qualify.
# WHILLY_IMAGE=mshegolev/whilly:4.6.0

# ─── Agent backend (which CLI executes the actual task) ───────────────────
# CLAUDE_BIN points at the binary the worker runs. Default keeps the
# zero-cost fake stub so first-run demos do not need credentials.
# Switch to a real CLI by overriding CLAUDE_BIN + setting the matching
# WHILLY_CLI route + provider API key below.
# CLAUDE_BIN=/opt/whilly/tests/fixtures/fake_claude_demo.sh
# FAKE_CLAUDE_DEMO_DELAY=2.5

# WHILLY_CLI=             # claude-code | opencode | gemini | codex (or empty for legacy)
# WHILLY_FORCE_COMPLETE=1

# ─── Provider credentials (only needed for non-stub backends) ─────────────
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENCODE_DEFAULT_PROVIDER=

# ─── Raw LLM shim (--llm groq|openrouter|cerebras|gemini|ollama|claude) ───
# Lower-cost route that bypasses agentic capabilities. Useful for
# CI-only smoke tests where filesystem tools are not needed.
# LLM_PROVIDER=
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# LLM_TIER_OVERRIDE=
# LLM_TIMEOUT=120
# LLM_TEMPERATURE=0
# LLM_HTTP_REFERER=
# LLM_X_TITLE=
# LLM_FORCE_COMPLETE=0

# ─── Public exposure (since the 2026-05-02 localhost.run pivot) ───────────
# Tailscale was removed from the architecture. Two-host worker reach is now
# either direct HTTP to a public VPS IP or the rotating
# https://<random>.lhr.life URL published by the M2 localhost.run `funnel`
# sidecar. See docs/Distributed-Setup.md for the localhost.run replacement
# (M2 — coming in v4.5).

# ─── Logging ──────────────────────────────────────────────────────────────
# WHILLY_LOG_LEVEL=INFO
