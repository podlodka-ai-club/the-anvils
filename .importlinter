[importlinter]
# Hexagonal architecture guard for Whilly v4.0 (PRD SC-6 / TC-8).
# whilly.core is the pure domain layer — no I/O, no networking, no subprocess.
# All side effects live in whilly.adapters.*.
root_packages =
    whilly
# Required by import-linter whenever a forbidden-imports contract names
# *external* packages (asyncpg, httpx, fastapi, ...). Without this flag the
# contract refuses to run with the explicit message:
#   "must have include_external_packages=True when there are external
#    forbidden modules"
# Setting it True tells import-linter to graph imports *into* the listed
# external packages so a transitive `whilly.core -> X -> asyncpg` is still
# caught by the SC-6 contract.
include_external_packages = True

[importlinter:contract:core-purity]
name = whilly.core must not import I/O or transport modules
type = forbidden
source_modules =
    whilly.core
forbidden_modules =
    asyncpg
    httpx
    subprocess
    fastapi
    uvicorn
    alembic
ignore_imports =
    # whilly.core may use stdlib `os` for os.path utilities, but tests assert
    # no os.chdir / os.getcwd call sites via grep in CI (see TASK-029).
    # whilly.core.triz is granted a documented exception to use subprocess /
    # shutil because the per-task TRIZ analyzer (TASK-104b) is pinned to
    # ``whilly/core/triz.py`` by the validation contract (VAL-TRIZ-006:
    # ``subprocess.run`` calls observable inside the module). The rest of
    # whilly.core stays pure — this exception is intentionally narrow.
    whilly.core.triz -> subprocess
    whilly.core.triz -> shutil

[importlinter:contract:worker-entry-purity]
# Static-graph guard for the v4.4.x worker-entry import closure
# (fix-m1-whilly-worker-fastapi-leak). The remote worker entry must not
# transitively import any control-plane-only top-level package: a worker
# box installs ``whilly-orchestrator[worker]`` (httpx + pydantic + base
# closure) and any leak surfaces at runtime as ModuleNotFoundError. The
# runtime gate (tests/integration/test_worker_image_import_purity.py)
# proves the *image* is clean; this contract proves the *graph* is clean
# so future regressions are caught at PR-review time.
name = whilly worker entry closure must not import server-only packages
type = forbidden
source_modules =
    whilly.cli.worker
    whilly.worker.remote
    whilly.adapters.transport.client
forbidden_modules =
    fastapi
    asyncpg
    sqlalchemy
    alembic
    uvicorn
    prometheus_client
    prometheus_fastapi_instrumentator
